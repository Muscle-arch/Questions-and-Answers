# 高德地图 JS API Key
# 申请地址: https://console.amap.com/dev/key/app
# 申请后将 Key 替换下方占位符
VITE_AMAP_JS_KEY=71c6f3452925e7ed83c8ae6e45a3a9ca

# 高德地图 Web Service Key（用于前端直接请求路径规划/地理编码 API）
# 未单独配置时会回退使用 VITE_AMAP_JS_KEY
VITE_AMAP_WEB_KEY=71c6f3452925e7ed83c8ae6e45a3a9ca

# API 基础路径
VITE_API_BASE=/api

# 是否使用 Mock 数据（后端未启动时设为 true）
VITE_USE_MOCK=true
